# 当前主提供者名称，值要与下面 PROVIDER_<NAME>_* 中的 NAME 对应。
# 例如：ark_v3 / ark_plan
PRIMARY_PROVIDER=ark_plan

# ark_v3：火山方舟 OpenAI 兼容 v3 接口。
# 适合直接走标准 /chat/completions 兼容地址。
PROVIDER_ARK_V3_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PROVIDER_ARK_V3_API_KEY=xxx-xxxxx-xxx-4b23-991f-xxxx-9f7f9
PROVIDER_ARK_V3_MODEL=doubao-seed-2-0-code-preview-260215

# ark_plan：火山方舟 plan v3 接口。
# 如果你要切到 plan 路由，就把 PRIMARY_PROVIDER 改成 ark_plan。
PROVIDER_ARK_PLAN_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
PROVIDER_ARK_PLAN_API_KEY=xxx-xxxxx-xxx-4b23-991f-xxxx-9f7f9
PROVIDER_ARK_PLAN_MODEL=glm-5.1

# 是否强制使用当前主提供者配置里的模型。
# 设为 1 后，会覆盖 Codex 请求里自带的 model，避免把不兼容模型名原样转发给上游。
FORCE_MODEL_OVERRIDE=1

# 基础调试日志开关。
# 设为 1 后，会打印请求摘要、上游状态码、流开始/结束等基础排查信息。
DEBUG_PROXY=0

# 详细调试日志开关。
# 设为 1 后，会额外打印原始请求体、转换后请求体、上游 SSE 输入、代理 SSE 输出。
# 排查 function_call 循环、response.completed 丢失、参数转换问题时建议临时打开。
DEBUG_PROXY_VERBOSE=0
